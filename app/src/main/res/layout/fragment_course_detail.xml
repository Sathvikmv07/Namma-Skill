<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarDetail"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="@color/primary"
            app:titleEnabled="false">

            <View
                android:id="@+id/headerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/primary"
                app:layout_collapseMode="parallax" />

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_arrow_back"
                app:menu="@menu/detail_menu" />
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title section -->
            <TextView
                android:id="@+id/tvCourseTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Course Title"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvCenterName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Center Name"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvDistrict"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 District"
                android:textSize="13sp"
                android:textColor="@color/secondary"
                android:layout_marginTop="4dp" />

            <!-- Info chips row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <com.google.android.material.chip.Chip
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 months"
                    android:clickable="false"
                    app:chipBackgroundColor="#F3E5F5" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/tvStartDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start: Feb 1"
                    android:clickable="false"
                    android:layout_marginStart="8dp"
                    app:chipBackgroundColor="#E3F2FD" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/tvSeats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20/25 seats"
                    android:clickable="false"
                    android:layout_marginStart="8dp"
                    app:chipBackgroundColor="#FFF3E0" />
            </LinearLayout>

            <!-- Job Guaranteed banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/bannerJobGuaranteed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#E8F5E9"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/success"
                app:strokeWidth="1dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="✅ Job Guaranteed — Placement assistance provided after course completion"
                    android:textSize="13sp"
                    android:textColor="@color/success"
                    android:fontFamily="sans-serif-medium" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Stipend card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStipend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFF8E1"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Monthly Stipend"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvStipend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹1500 / month"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="#F57F17" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Seat Progress -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Seat Availability"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_primary"
                android:layout_marginTop="20dp" />

            <ProgressBar
                android:id="@+id/seatProgress"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                android:progressTint="@color/primary"
                android:layout_marginTop="8dp" />

            <!-- About -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="About This Course"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_primary"
                android:layout_marginTop="20dp" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp"
                android:layout_marginTop="8dp" />

            <!-- Eligibility -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Eligibility"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_primary"
                android:layout_marginTop="20dp" />

            <TextView
                android:id="@+id/tvEligibility"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 10th Pass\n• Age 18-35"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp" />

            <!-- Trainer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your Trainer"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/text_primary"
                android:layout_marginTop="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tvTrainerName"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Trainer Name"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary" />

                <Button
                    android:id="@+id/btnCallTrainer"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="📞 Call"
                    android:textSize="13sp"
                    android:backgroundTint="@color/secondary"
                    app:cornerRadius="20dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- Sticky Bottom Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <Button
            android:id="@+id/btnApplyNow"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Apply Now"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            android:backgroundTint="@color/primary"
            app:cornerRadius="12dp" />

        <Button
            android:id="@+id/btnRequestCallback"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Request Callback"
            style="@style/Widget.Material3.Button.TextButton"
            android:textColor="@color/secondary" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
