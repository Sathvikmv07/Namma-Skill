<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: icon + title + duration badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivTradeIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="8dp"
                android:background="@drawable/trade_icon_bg"
                android:src="@drawable/ic_trade_default"
                android:contentDescription="Trade icon" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvCourseTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Course Title"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/text_primary"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvCenterName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Center Name"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Short"
                android:textSize="11sp"
                android:textColor="@android:color/white"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@drawable/badge_rounded"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginVertical="12dp" />

        <!-- Info row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDistrict"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📍 District"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvStartDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🗓 Start date"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:gravity="end" />
        </LinearLayout>

        <!-- Seats + stipend -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvSeatsLeft"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🪑 20 seats left"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvStipend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹1500/month"
                android:textSize="12sp"
                android:textColor="@color/success"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Job Guaranteed chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipJobGuaranteed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅ Job Guaranteed"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            app:chipBackgroundColor="#E8F5E9"
            app:chipStrokeColor="@color/success"
            app:chipStrokeWidth="1dp"
            android:textColor="@color/success"
            android:clickable="false"
            android:focusable="false" />

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnApplyNow"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Apply Now"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/primary"
                android:layout_marginEnd="6dp"
                app:cornerRadius="12dp" />

            <Button
                android:id="@+id/btnInterested"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="I'm Interested"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/primary"
                android:textColor="@color/primary"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
